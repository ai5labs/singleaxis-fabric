# Copy to .env and edit as needed. All values below are the defaults
# baked into docker-compose.yml — uncommenting them changes nothing
# unless you also rotate the matching value on the server side.

# --- Langfuse ---------------------------------------------------------
# Public/secret keys must match LANGFUSE_INIT_PROJECT_{PUBLIC,SECRET}_KEY
# in docker-compose.yml. LANGFUSE_BASIC_AUTH is base64(public:secret)
# consumed by the otel-collector's otlphttp exporter.
#
# LANGFUSE_PUBLIC_KEY=pk-lf-harness
# LANGFUSE_SECRET_KEY=sk-lf-harness
# LANGFUSE_BASIC_AUTH=cGstbGYtaGFybmVzczpzay1sZi1oYXJuZXNz
# LANGFUSE_PROJECT_ID=fabric-harness
# LANGFUSE_USER_EMAIL=admin@fabric.local
# LANGFUSE_USER_PASSWORD=fabric-admin

# --- Langfuse Postgres -----------------------------------------------
# LANGFUSE_DB_PASSWORD=langfuse

# --- Langfuse auth secrets -------------------------------------------
# Regenerate for anything beyond local dev:
#   openssl rand -base64 32
# LANGFUSE_NEXTAUTH_SECRET=harness-nextauth-secret-change-me
# LANGFUSE_SALT=harness-salt-change-me

# --- Fabric profile --------------------------------------------------
# Used by the optional langfuse-bootstrap service to pick which
# curated dashboards/scores/filters to apply.
# FABRIC_PROFILE=permissive-dev
